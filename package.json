{
  "name": "conversation-quality-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "API de avaliação de qualidade de conversas de atendimento via LLM-as-judge",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/api/index.ts",
    "start": "node --env-file-if-exists=.env dist/api/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^5.10.0",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1.0",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
