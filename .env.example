# OpenAI API key (required). Never commit the real key.
OPENAI_API_KEY=sk-your-key-here

# Default model used when the request does not specify one.
DEFAULT_MODEL=gpt-5.4-mini

# Conversation token limit before truncating (head+tail). Deliberately below
# the model's window: the judge's quality degrades before the technical limit.
# Validated on boot against DEFAULT_MODEL: this value plus a fixed reserve
# (system prompt + rubric + JSON Schema + response) must fit the model's
# context window, or the process refuses to start.
MAX_CONVERSATION_TOKENS=30000

# Maximum number of concurrent LLM calls in the process (protects OpenAI quota).
LLM_MAX_CONCURRENCY=5

# HTTP port of the API.
PORT=3000

# Path to the SQLite audit file.
DB_PATH=./data/evaluations.db

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
